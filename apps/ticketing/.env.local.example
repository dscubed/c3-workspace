# Supabase — same project as connect3.app
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=your-supabase-anon-key

# Service-role key (server-only, never expose to client)
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# SSO configuration — defaults to localhost:3000 in development
# Set to https://connect3.app/auth/sso in production
NEXT_PUBLIC_SSO_BASE_URL=https://connect3.app/auth/sso